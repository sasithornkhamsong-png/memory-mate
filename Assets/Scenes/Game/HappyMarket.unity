  m_Script: {fileID: 11500000, guid: fe7a86e336868c74abfe7c8df1608a88, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::SortingGameManager
  memorizePanel: {fileID: 1193740990}
  arrangePanel: {fileID: 1076277402}
  optionButtons:
